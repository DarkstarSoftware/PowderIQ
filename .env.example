# ─── OpenWeather (optional — uses mock data if omitted) ──────────────────────
OPENWEATHER_API_KEY=""

# ─── Resend email (optional — logs to console if omitted) ────────────────────
RESEND_API_KEY=""
RESEND_FROM_EMAIL="noreply@powderiq.com"

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
CRON_SECRET="change-me-to-a-long-random-string"
